# Copy this file to .env and fill in real values.

# --- App ---
PROJECT_NAME=GST Billing API
DEBUG=true
API_PREFIX=/api

# --- Database (PostgreSQL on Neon) ---
# For Neon, copy the full connection string here. It will look like:
# postgresql://user:password@ep-something-123456.us-east-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL="your-neon-database-url-goes-here"

# --- Fallback for local PostgreSQL (if DATABASE_URL is empty) ---
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-local-db-password
DB_NAME=gst_billing

# --- Security ---
# Generate a strong key:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- CORS (comma-separated origins, or * for all during development) ---
CORS_ORIGINS=*

# --- First super admin (created by the seed script) ---
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=ChangeThisStrongPassword123!
SUPER_ADMIN_NAME=Platform Owner
