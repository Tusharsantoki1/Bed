# Copy this file to .env and fill in real values.

# --- App ---
PROJECT_NAME=GST Billing API
DEBUG=true

# --- Database (MySQL) ---
# Give the parts separately. The password is URL-encoded for you, so
# special characters (@ ! # ...) need NO manual escaping.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=gst_billing
# Optional full-URL override (leave empty to use the parts above):
DATABASE_URL=

# --- Security ---
# Generate a strong key:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- CORS (comma-separated origins, or * for all during development) ---
CORS_ORIGINS=*

# --- First super admin (created by the seed script) ---
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=ChangeThisStrongPassword123!
SUPER_ADMIN_NAME=Platform Owner
